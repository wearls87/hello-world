
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Price Support — Dashboard + Chat · Approach 1</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,500;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1e293b;
    --ink-soft: #475569;
    --ink-muted: #64748b;
    --ink-faint: #94a3b8;
    --surface: #ffffff;
    --surface-raised: #f8fafc;
    --surface-sunken: #f1f5f9;
    --border: #e2e8f0;
    --border-light: #f1f5f9;
    --accent: #4f46e5;
    --accent-soft: #eef2ff;
    --accent-border: #c7d2fe;
    --accent-deep: #4338ca;
    --accent-text: #312e81;
    --green: #16a34a;
    --green-bg: #dcfce7;
    --blue: #2563eb;
    --blue-bg: #dbeafe;
    --amber: #d97706;
    --amber-bg: #fef3c7;
    --slate: #64748b;
    --slate-bg: #f1f5f9;
    --red: #dc2626;
    --red-bg: #fef2f2;
    --header-bg: #1e1b4b;
    --radius: 8px;
    --radius-sm: 6px;
    --radius-pill: 20px;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 30px rgba(0,0,0,0.12);
    --font: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', monospace;
    --transition: 0.18s cubic-bezier(0.4, 0, 0.2, 1);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--font);
    color: var(--ink);
    background: var(--surface);
    height: 100vh;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── LAYOUT ─────────────────────────── */
  #app {
    display: flex;
    flex-direction: column;
    height: 100vh;
  }

  .header {
    background: var(--header-bg);
    color: #fff;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }
  .header-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 14px;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.15);
  }
  .header h1 { font-size: 15px; font-weight: 700; letter-spacing: -0.01em; }
  .header .subtitle { font-size: 11px; opacity: 0.6; margin-top: 2px; }

  /* ─── FILTER BAR ─────────────────────── */
  .filters {
    padding: 10px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface-raised);
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }
  .filter-btn {
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--ink-muted);
    cursor: pointer;
    transition: all var(--transition);
    letter-spacing: 0.01em;
  }
  .filter-btn:hover {
    border-color: var(--accent-border);
    color: var(--accent);
    background: var(--accent-soft);
  }
  .filter-btn.active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    font-weight: 700;
    box-shadow: var(--shadow-sm);
  }

  /* ─── CAMPAIGN TABLE ─────────────────── */
  .table-wrap { flex: 1; overflow: auto; }
  .campaign-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .campaign-table thead { position: sticky; top: 0; z-index: 2; }
  .campaign-table th {
    padding: 8px 14px;
    text-align: left;
    font-weight: 700;
    color: var(--ink-soft);
    background: var(--surface-raised);
    border-bottom: 2px solid var(--border);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .campaign-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-light);
    transition: background var(--transition);
  }
  .campaign-table tbody tr {
    cursor: pointer;
    transition: background var(--transition);
  }
  .campaign-table tbody tr:hover {
    background: var(--accent-soft);
  }
  .campaign-table tbody tr:hover td:nth-child(2) {
    color: var(--accent);
  }
  .campaign-name {
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .campaign-dates { color: var(--ink-muted); font-size: 11px; }
  .campaign-div { font-size: 11px; }
  .campaign-sales { font-weight: 700; font-family: var(--mono); font-size: 12px; }
  .campaign-gm { font-family: var(--mono); font-size: 12px; }
  .campaign-gm.low { color: var(--red); font-weight: 600; }
  .campaign-dr { font-family: var(--mono); font-size: 11px; color: var(--ink-muted); }

  /* ─── STATUS BADGES ──────────────────── */
  .badge {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .badge-complete { background: var(--green-bg); color: var(--green); }
  .badge-active   { background: var(--blue-bg);  color: var(--blue); }
  .badge-upcoming { background: var(--amber-bg); color: var(--amber); }
  .badge-planned  { background: var(--slate-bg); color: var(--slate); }

  /* ─── DETAIL VIEW ────────────────────── */
  .detail-view {
    display: flex;
    flex-direction: column;
    height: 100vh;
  }
  .detail-header {
    background: var(--surface-raised);
    border-bottom: 1px solid var(--border);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .back-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    transition: background var(--transition);
  }
  .back-btn:hover { background: var(--accent-soft); }
  .detail-title { font-weight: 700; font-size: 15px; letter-spacing: -0.01em; }
  .detail-meta { font-size: 11px; color: var(--ink-muted); margin-top: 1px; }
  .detail-meta .status { font-weight: 700; }

  /* ─── TABS ───────────────────────────── */
  .tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    background: var(--surface);
  }
  .tab-btn {
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font);
    color: var(--ink-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all var(--transition);
    letter-spacing: 0.01em;
  }
  .tab-btn:hover { color: var(--accent); }
  .tab-btn.active {
    color: var(--accent);
    font-weight: 700;
    border-bottom-color: var(--accent);
  }

  /* ─── METRIC CARDS ───────────────────── */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    padding: 18px;
  }
  .metric-card {
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 10px;
    text-align: center;
    transition: all var(--transition);
  }
  .metric-card:hover {
    border-color: var(--accent-border);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }
  .metric-icon { font-size: 18px; margin-bottom: 4px; }
  .metric-label {
    font-size: 9px;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .metric-value {
    font-weight: 700;
    font-size: 18px;
    font-family: var(--mono);
    margin-top: 2px;
    letter-spacing: -0.02em;
  }
  .metric-value.empty { color: #cbd5e1; }

  .no-data-card {
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    text-align: center;
    color: var(--ink-muted);
    margin: 18px;
    font-size: 13px;
  }

  /* ─── LY COMPARISON ──────────────────── */
  .ly-wrap { padding: 18px; }
  .ly-headers {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }
  .ly-card {
    flex: 1;
    border-radius: var(--radius);
    padding: 14px;
  }
  .ly-card.ty { background: var(--accent-soft); border: 1px solid var(--accent-border); }
  .ly-card.ly { background: #f5f5f4; border: 1px solid #d6d3d1; }
  .ly-label {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .ly-card.ty .ly-label { color: var(--accent); }
  .ly-card.ly .ly-label { color: #78716c; }
  .ly-name { font-weight: 700; margin-top: 3px; font-size: 13px; }
  .ly-sub { font-size: 10px; color: var(--ink-muted); margin-top: 1px; }

  .ly-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    font-size: 13px;
  }
  .ly-table th {
    padding: 10px 14px;
    text-align: left;
    font-weight: 700;
    background: var(--surface-raised);
    border-bottom: 2px solid var(--border);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
  .ly-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-light);
  }
  .ly-table .metric-name { font-weight: 600; }
  .ly-table .ly-val { color: var(--ink-muted); }
  .delta-pos { color: var(--green); font-weight: 700; font-family: var(--mono); }
  .delta-neg { color: var(--red); font-weight: 700; font-family: var(--mono); }
  .delta-na  { color: var(--ink-faint); font-size: 11px; }

  .no-ly-card {
    background: var(--amber-bg);
    border: 1px solid #fde68a;
    border-radius: var(--radius);
    padding: 32px;
    text-align: center;
  }
  .no-ly-icon { font-size: 32px; margin-bottom: 8px; }
  .no-ly-title { font-weight: 700; color: #92400e; font-size: 14px; }
  .no-ly-sub { font-size: 12px; color: #a16207; margin-top: 6px; }

  /* ─── CHAT ───────────────────────────── */
  .chat-container {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }
  .chat-messages {
    flex: 1;
    overflow: auto;
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .msg { max-width: 82%; animation: msgIn 0.25s ease-out; }
  .msg.agent { align-self: flex-start; }
  .msg.user  { align-self: flex-end; }
  .msg-bubble {
    padding: 10px 16px;
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.55;
    white-space: pre-wrap;
    box-shadow: var(--shadow-sm);
  }
  .msg.agent .msg-bubble {
    background: var(--surface-sunken);
    color: var(--ink);
    border-bottom-left-radius: 4px;
  }
  .msg.user .msg-bubble {
    background: var(--accent);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .quick-prompts {
    display: flex;
    gap: 6px;
    padding: 8px 14px;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .prompt-btn {
    background: var(--accent-soft);
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-pill);
    padding: 5px 14px;
    font-size: 11px;
    font-family: var(--font);
    cursor: pointer;
    color: var(--accent-deep);
    transition: all var(--transition);
    font-weight: 500;
  }
  .prompt-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .chat-input-bar {
    padding: 10px 14px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    background: var(--surface);
  }
  .chat-input {
    flex: 1;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 14px;
    font-size: 13px;
    font-family: var(--font);
    outline: none;
    transition: border var(--transition);
  }
  .chat-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,70,229,0.1); }
  .chat-input::placeholder { color: var(--ink-faint); }
  .send-btn {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    padding: 10px 20px;
    cursor: pointer;
    font-weight: 700;
    font-size: 13px;
    font-family: var(--font);
    transition: all var(--transition);
    letter-spacing: 0.01em;
  }
  .send-btn:hover { background: var(--accent-deep); box-shadow: var(--shadow-md); }

  /* ─── UTILITIES ──────────────────────── */
  .hidden { display: none !important; }

  /* scrollbar styling */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>
</head>
<body>

<div id="app">
  <!-- ═══ DASHBOARD VIEW ═══ -->
  <div id="dashboard-view">
    <div class="header">
      <div class="header-icon">PS</div>
      <div>
        <h1>Price Support — Dashboard + Chat</h1>
        <div class="subtitle">Approach 1 · Click any campaign to open detail view</div>
      </div>
    </div>
    <div class="filters" id="filters"></div>
    <div class="table-wrap">
      <table class="campaign-table">
        <thead>
          <tr>
            <th style="width:90px">Status</th>
            <th>Campaign</th>
            <th>Dates</th>
            <th>Division</th>
            <th>Sales</th>
            <th>GM%</th>
            <th>D/R</th>
          </tr>
        </thead>
        <tbody id="campaign-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- ═══ DETAIL VIEW ═══ -->
  <div id="detail-view" class="detail-view hidden">
    <div class="detail-header">
      <button class="back-btn" onclick="showDashboard()">← Back</button>
      <div>
        <div class="detail-title" id="detail-title"></div>
        <div class="detail-meta" id="detail-meta"></div>
      </div>
    </div>
    <div class="tabs" id="detail-tabs"></div>
    <div id="tab-content" style="flex:1;overflow:auto;display:flex;flex-direction:column;min-height:0;"></div>
  </div>
</div>

<script>
// ─── DATA ────────────────────────────────────────────────────────────────
const N=["New Year Kickoff","Winter Clearance","Valentine's Preview","Valentine's Day","Presidents Day","Spring Preview","Friends & Family","Spring Break","Spring Kickoff","BOGO Denim","Easter Weekend","Spring Refresh","$5 Dresses","Earth Day Capsule","Mother's Day","Memorial Day","Summer Kickoff","Fourth of July","Mid-Summer MD","Back to School"];
const DT=["Jan 5–11","Jan 12–25","Jan 26–Feb 1","Feb 9–15","Feb 14–17","Feb 23–Mar 1","Mar 2–8","Mar 9–22","Mar 2–15","Mar 16–22","Mar 23–Apr 5","Apr 6–19","Apr 20–26","Apr 22–26","May 4–10","May 23–26","Jun 1–14","Jul 1–5","Jul 13–26","Jul 27–Aug 9"];
const DV=["Women's","Men's","Women's","Acc","Men's","Women's","All","Women's","Women's","Women's","All","Women's","Women's","Women's","Acc","All","Men's","All","Women's","Kids"];
const SL=["$3.1M","$5.8M","$2.4M","$4.6M","$3.9M","$2.8M","$8.2M","$6.1M","$4.2M","$1.9M","$5.1M","—","—","—","—","—","—","—","—","—"];
const GM=["41.2%","22.4%","44.1%","32.8%","36.5%","48.2%","29.6%","33.8%","38.2%","26.8%","28.4%","—","—","—","—","—","—","—","—","—"];
const DR=["30%","58%","25%","42%","38%","20%","40%","35%","32%","50%","50%","25%","61%","15%","30%","50%","20%","40%","55%","25%"];
const CV=["4.1%","5.3%","3.8%","5.6%","4.9%","3.5%","5.8%","5.0%","4.6%","5.2%","5.1%","—","—","—","—","—","—","—","—","—"];
const ST=["C","C","C","C","C","C","C","C","C","C","A","U","U","U","P","P","P","P","P","P"];
const LN=["New Year Sale","Winter Clearance","Val Preview","Valentine's Day","Presidents Day","Spring Preview","Friends & Family","Spring Break","Spring Event","Denim BOGO","Easter Wknd","Spring MD","$5 Dresses","","Mother's Day","Memorial Day","Summer Launch","July 4th","Summer Clear","BTS Early"];
const LS=["$2.6M","$4.9M","$1.9M","$3.8M","$3.2M","$2.1M","$6.8M","$4.8M","$3.5M","$1.5M","$4.4M","$1.8M","$1.8M","","$2.1M","$5.6M","$2.4M","$4.8M","$3.2M","$3.6M"];
const LG=["43.1%","20.8%","45.8%","34.2%","38.1%","49.5%","31.4%","35.6%","40.1%","28.4%","30.2%","38.5%","18.2%","","42.3%","30.1%","46.2%","32.4%","21.6%","39.8%"];
const LD=["25%","60%","20%","40%","35%","15%","35%","30%","28%","50%","40%","25%","62%","","25%","45%","15%","35%","52%","20%"];
const SX={C:"Complete",A:"Active",U:"Upcoming",P:"Planned"};

// ─── STATE ───────────────────────────────────────────────────────────────
let currentFilter = "All";
let selectedIdx = null;
let currentTab = "metrics";
let chatMessages = [];

// ─── HELPERS ─────────────────────────────────────────────────────────────
function badgeClass(st) {
  return {C:"badge-complete",A:"badge-active",U:"badge-upcoming",P:"badge-planned"}[st];
}
function statusColor(st) {
  return {C:"#16a34a",A:"#2563eb",U:"#d97706",P:"#64748b"}[st];
}
function delta(a, b) {
  const x = parseFloat(a.replace(/[$%MK,]/g, "")),
        y = parseFloat(b.replace(/[$%MK,]/g, ""));
  if (isNaN(x) || isNaN(y) || !y) return null;
  return ((x - y) / Math.abs(y) * 100).toFixed(1);
}
function deltaStr(a, b) {
  const d = delta(a, b);
  if (d === null) return '<span class="delta-na">—</span>';
  const pos = parseFloat(d) >= 0;
  return `<span class="${pos ? 'delta-pos' : 'delta-neg'}">${pos ? '+' : ''}${d}%</span>`;
}

// ─── FILTERS ─────────────────────────────────────────────────────────────
function buildFilters() {
  const el = document.getElementById("filters");
  const statuses = ["All","Complete","Active","Upcoming","Planned"];
  el.innerHTML = statuses.map(s =>
    `<button class="filter-btn ${currentFilter === s ? 'active' : ''}" onclick="setFilter('${s}')">${s}</button>`
  ).join("");
}
function setFilter(f) {
  currentFilter = f;
  buildFilters();
  renderTable();
}

// ─── TABLE ───────────────────────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById("campaign-tbody");
  let html = "";
  for (let i = 0; i < 20; i++) {
    if (currentFilter !== "All" && SX[ST[i]] !== currentFilter) continue;
    const gmLow = GM[i] !== "—" && parseFloat(GM[i]) < 30;
    html += `
      <tr onclick="openDetail(${i})">
        <td><span class="badge ${badgeClass(ST[i])}">${SX[ST[i]]}</span></td>
        <td class="campaign-name">${N[i]}</td>
        <td class="campaign-dates">${DT[i]}</td>
        <td class="campaign-div">${DV[i]}</td>
        <td class="campaign-sales">${SL[i]}</td>
        <td class="campaign-gm ${gmLow ? 'low' : ''}">${GM[i]}</td>
        <td class="campaign-dr">${DR[i]}</td>
      </tr>`;
  }
  tbody.innerHTML = html;
}

// ─── DETAIL VIEW ─────────────────────────────────────────────────────────
function openDetail(i) {
  selectedIdx = i;
  currentTab = "metrics";
  chatMessages = [{ a: true, t: N[i] + " loaded. Ask about performance, LY comparison, or recommendations." }];
  document.getElementById("dashboard-view").classList.add("hidden");
  document.getElementById("detail-view").classList.remove("hidden");
  renderDetail();
}
function showDashboard() {
  selectedIdx = null;
  document.getElementById("detail-view").classList.add("hidden");
  document.getElementById("dashboard-view").classList.remove("hidden");
}

function renderDetail() {
  const i = selectedIdx;
  document.getElementById("detail-title").textContent = N[i];
  document.getElementById("detail-meta").innerHTML =
    `${DT[i]} · ${DV[i]} · <span class="status" style="color:${statusColor(ST[i])}">${SX[ST[i]]}</span>`;

  // tabs
  const tabs = [["metrics","Overview"],["ly","LY Compare"],["chat","💬 Ask Agent"]];
  document.getElementById("detail-tabs").innerHTML = tabs.map(([k, l]) =>
    `<button class="tab-btn ${currentTab === k ? 'active' : ''}" onclick="switchTab('${k}')">${l}</button>`
  ).join("");

  renderTabContent();
}

function switchTab(t) {
  currentTab = t;
  renderDetail();
}

function renderTabContent() {
  const el = document.getElementById("tab-content");
  const i = selectedIdx;

  if (currentTab === "metrics") {
    if (SL[i] !== "—") {
      const cards = [["Sales",SL[i],"💰"],["GM%",GM[i],"📊"],["Conv",CV[i],"🎯"],["D/R",DR[i],"📉"]];
      el.innerHTML = `<div class="metrics-grid">${cards.map(([l,v,ic]) => `
        <div class="metric-card">
          <div class="metric-icon">${ic}</div>
          <div class="metric-label">${l}</div>
          <div class="metric-value">${v}</div>
        </div>`).join("")}</div>`;
    } else {
      el.innerHTML = `<div class="no-data-card">No performance data yet · Planned D/R: ${DR[i]}</div>`;
    }
  }

  else if (currentTab === "ly") {
    const hasLY = !!LN[i];
    if (hasLY) {
      const rows = [["Sales",SL[i],LS[i]],["GM%",GM[i],LG[i]],["D/R",DR[i],LD[i]]];
      el.innerHTML = `
        <div class="ly-wrap">
          <div class="ly-headers">
            <div class="ly-card ty">
              <div class="ly-label">This Year</div>
              <div class="ly-name">${N[i]}</div>
              <div class="ly-sub">${DT[i]}</div>
            </div>
            <div class="ly-card ly">
              <div class="ly-label">Last Year</div>
              <div class="ly-name">${LN[i]}</div>
              <div class="ly-sub">D/R ${LD[i]}</div>
            </div>
          </div>
          <table class="ly-table">
            <thead><tr><th>Metric</th><th>TY</th><th>LY</th><th>Δ</th></tr></thead>
            <tbody>${rows.map(([m,a,b]) => `
              <tr>
                <td class="metric-name">${m}</td>
                <td style="font-family:var(--mono)">${a}</td>
                <td class="ly-val" style="font-family:var(--mono)">${b}</td>
                <td>${deltaStr(a,b)}</td>
              </tr>`).join("")}
            </tbody>
          </table>
        </div>`;
    } else {
      el.innerHTML = `
        <div class="ly-wrap">
          <div class="no-ly-card">
            <div class="no-ly-icon">📭</div>
            <div class="no-ly-title">No LY Campaign</div>
            <div class="no-ly-sub">No comparable campaign scheduled last year for this block.</div>
          </div>
        </div>`;
    }
  }

  else if (currentTab === "chat") {
    el.innerHTML = `
      <div class="chat-container">
        <div class="chat-messages" id="chat-messages"></div>
        <div class="quick-prompts">
          <button class="prompt-btn" onclick="sendChat('How did this perform?')">Performance?</button>
          <button class="prompt-btn" onclick="sendChat('Compare to LY')">Compare LY</button>
          <button class="prompt-btn" onclick="sendChat('What do you recommend?')">Recs</button>
        </div>
        <div class="chat-input-bar">
          <input class="chat-input" id="chat-input" placeholder="Ask about this campaign..." onkeydown="if(event.key==='Enter')sendFromInput()">
          <button class="send-btn" onclick="sendFromInput()">Send</button>
        </div>
      </div>`;
    renderChatMessages();
    // focus input
    setTimeout(() => document.getElementById("chat-input")?.focus(), 50);
  }
}

// ─── CHAT LOGIC ──────────────────────────────────────────────────────────
function sendFromInput() {
  const input = document.getElementById("chat-input");
  if (!input || !input.value.trim()) return;
  sendChat(input.value.trim());
  input.value = "";
}

function sendChat(q) {
  const i = selectedIdx;
  const lo = q.toLowerCase();
  let t = "Try asking about: performance, compare LY, or recommendations.";
  const hasLY = !!LN[i];

  if (/per|how/.test(lo)) {
    t = "📊 " + N[i] + ":\n\nSales: " + SL[i] + "\nGM%: " + GM[i] + "\nConversion: " + CV[i] + "\nDiscount Rate: " + DR[i];
    if (hasLY) t += "\n\nvs LY (" + LN[i] + "): " + LS[i] + " | GM% " + LG[i];
  }
  if (/ly|comp/.test(lo)) {
    t = hasLY
      ? "📅 vs LY — " + LN[i] + ":\n\nSales: " + SL[i] + " vs " + LS[i] + "\nGM%: " + GM[i] + " vs " + LG[i] + "\nD/R: " + DR[i] + " vs " + LD[i]
      : "No LY campaign available for this promo block.";
  }
  if (/rec|sug/.test(lo)) {
    t = parseFloat(GM[i]) < 30
      ? "⚠️ GM% at " + GM[i] + " is below the 30% target.\n\nRecommend reducing discount depth by 5–10% for the next similar event to recover margin."
      : "✅ GM% at " + GM[i] + " is healthy.\n\nCurrent discount strategy is sustainable. Maintain approach for future comparable events.";
  }

  chatMessages.push({ a: false, t: q });
  chatMessages.push({ a: true, t: t });
  renderChatMessages();
}

function renderChatMessages() {
  const el = document.getElementById("chat-messages");
  if (!el) return;
  el.innerHTML = chatMessages.map(m => `
    <div class="msg ${m.a ? 'agent' : 'user'}">
      <div class="msg-bubble">${escapeHtml(m.t)}</div>
    </div>`).join("");
  el.scrollTop = el.scrollHeight;
}

function escapeHtml(text) {
  return text.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/\n/g,"<br>");
}

// ─── INIT ────────────────────────────────────────────────────────────────
buildFilters();
renderTable();
</script>
